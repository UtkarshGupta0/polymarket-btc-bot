# === Polymarket Credentials (only needed for live mode) ===
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1

# === Trading Parameters ===
STARTING_CAPITAL=30.0
MAX_BET_SIZE=5.0
MIN_BET_SIZE=1.0
MIN_CONFIDENCE=0.60
ENTRY_WINDOW_START=45
ENTRY_WINDOW_END=8
MAX_DAILY_DRAWDOWN=5.0
MAX_CONSECUTIVE_LOSSES=5
MIN_RESERVE=5.0
KELLY_FRACTION=0.25

# === Telegram (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Anthropic (for self-improvement, optional) ===
ANTHROPIC_API_KEY=

# === Mode ===
TRADING_MODE=paper

# === Entry Reprice & Kelly Transition ===
# Seconds between each reprice attempt during the entry window
REPRICE_INTERVAL_SEC=5

# Number of resolved bets before switching from flat-bet to Kelly sizing
KELLY_ENABLE_AFTER=100

# === Entry Gate Parameters ===
# Minimum ask price allowed; rejects near-certain outcomes (illiquid)
GATE_ASK_MIN=0.15

# Maximum ask price allowed; rejects near-certain outcomes (illiquid)
GATE_ASK_MAX=0.92

# Minimum edge (confidence - ask) required to enter; 0.02 = 2%
MIN_EDGE=0.02

# Minimum absolute BTC price delta (%) required to enter; 0.0 = disabled
MIN_DELTA_PCT=0.0

# Number of consecutive cancel failures before pausing entry
CANCEL_FAIL_THRESHOLD=3

# In paper mode, hold position even if edge is lost (1=hold, 0=cancel)
PAPER_HOLD_ON_EDGE_LOSS=1

# === Signal Switches ===
# Enable BTC trend signal (1=on, 0=off)
SIGNAL_TREND_ENABLED=1

# Comma-separated UTC hours to skip trading; empty = always trade
# Example: "0,2,3,20,21"
TRADING_HOURS_BLOCK=

# === Dashboard ===
# Enable the Flask dashboard (1=on, 0=off)
DASHBOARD_ENABLED=1

# Host to bind the dashboard server to
DASHBOARD_HOST=127.0.0.1

# Port for the dashboard server
DASHBOARD_PORT=8787

# === External API Endpoints ===
# Binance WebSocket URL for BTC/USDT trade stream
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@aggTrade

# Binance REST API base URL
BINANCE_REST_URL=https://api.binance.com

# Polymarket Gamma API base URL
GAMMA_API_URL=https://gamma-api.polymarket.com

# Polymarket CLOB API base URL
CLOB_API_URL=https://clob.polymarket.com
